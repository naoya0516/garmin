# Garmin Connectアカウント認証情報（.envにコピーして編集。.envは.gitignore対象）
GARMIN_EMAIL=your-email@example.com
GARMIN_PASSWORD=your-password

# 同期時にGarminから取得する直近日数（既定30日）。
# 28日未満にするとサマリー(直近28日間)が未同期期間を含んでしまう点に注意。
SYNC_LOOKBACK_DAYS=30

# SQLiteのDB接続文字列
DATABASE_URL=sqlite:///./data/garmin.db

# garminconnectのトークンキャッシュ保存先（scripts/init_login.pyが生成する）
TOKENSTORE_PATH=~/.garminconnect

# フロントエンドのオリジン（CORS許可用）
CORS_ALLOW_ORIGIN=http://localhost:5173
